rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Energy Balance ──
    match /goalSettings/{docId} {
      allow read, write: if request.auth != null;
    }

    match /meals/{docId} {
      allow read, write: if request.auth != null;
    }

    match /cardioEntries/{docId} {
      allow read, write: if request.auth != null;
    }

    match /dailySteps/{docId} {
      allow read, write: if request.auth != null;
    }

    match /weightEntries/{docId} {
      allow read, write: if request.auth != null;
    }

    match /dailySummaries/{docId} {
      allow read, write: if request.auth != null;
    }

    match /weeklySummaries/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Workouts ──
    match /workoutPlans/{docId} {
      allow read, write: if request.auth != null;
    }

    match /workoutSessions/{docId} {
      allow read, write: if request.auth != null;
    }

    match /exercises/{docId} {
      allow read, write: if request.auth != null;
    }

    match /personalRecords/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
